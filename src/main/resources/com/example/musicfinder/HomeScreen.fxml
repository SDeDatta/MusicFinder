<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.musicfinder.HomeController"
           styleClass="root-pane">

    <VBox styleClass="home-background" alignment="CENTER" spacing="0">

        <!-- App title — always visible -->
        <VBox alignment="CENTER" spacing="8">
            <padding><Insets top="80"/></padding>
            <Label text="MUSIQ" styleClass="app-title"/>
            <Label text="Discover music through language"
                   styleClass="app-subtitle"/>
        </VBox>

        <!-- Step indicator -->
        <HBox fx:id="stepIndicator" alignment="CENTER" spacing="12">
            <padding><Insets top="32" bottom="0"/></padding>

            <!-- Step 1 dot -->
            <StackPane>
                <Circle fx:id="step1Dot"
                                           radius="8" styleClass="step-dot-active"/>
                <Label text="1" styleClass="step-dot-label"/>
            </StackPane>

            <!-- Connector line -->
            <Rectangle
                    fx:id="stepConnector"
                    width="60" height="2"
                    styleClass="step-connector"/>

            <!-- Step 2 dot -->
            <StackPane>
                <Circle fx:id="step2Dot"
                                           radius="8" styleClass="step-dot-inactive"/>
                <Label text="2" styleClass="step-dot-label"/>
            </StackPane>
        </HBox>

        <!-- Step labels -->
        <HBox alignment="CENTER" spacing="0">
            <padding><Insets top="8" bottom="32"/></padding>
            <Label fx:id="step1Label"
                   text="Choose a seed song"
                   styleClass="step-label-active"
                   prefWidth="76"
                   alignment="CENTER"/>
            <Region prefWidth="60"/>
            <Label fx:id="step2Label"
                   text="Refine your vibe"
                   styleClass="step-label-inactive"
                   prefWidth="76"
                   alignment="CENTER"/>
        </HBox>

        <!-- STEP 1 PANEL — Seed song input -->
        <VBox fx:id="step1Panel" alignment="CENTER" spacing="16" maxWidth="560">

            <Label text="What song do you want to start from?"
                   styleClass="step-question"/>
            <Label text="This is your seed song — recommendations will radiate out from it."
                   styleClass="step-hint"
                   wrapText="true"
                   maxWidth="480"
                   textAlignment="CENTER"/>

            <HBox alignment="CENTER" spacing="12">
                <TextField fx:id="seedField"
                           promptText="e.g.  Clocks by Coldplay"
                           styleClass="search-field"
                           prefHeight="52"
                           prefWidth="420"
                           onAction="#handleSeedNext"/>
                <Button text="→"
                        styleClass="search-button"
                        prefHeight="52"
                        prefWidth="52"
                        onAction="#handleSeedNext"/>
            </HBox>

            <!-- Example seed chips -->
            <HBox alignment="CENTER" spacing="10">
                <padding><Insets top="8"/></padding>
                <Label text="Try:" styleClass="option-label"/>
                <Button text="Clocks · Coldplay"
                        styleClass="example-chip"
                        onAction="#handleChipClocks"/>
                <Button text="Lose Yourself · Eminem"
                        styleClass="example-chip"
                        onAction="#handleChipEminem"/>
                <Button text="Bohemian Rhapsody · Queen"
                        styleClass="example-chip"
                        onAction="#handleChipQueen"/>
            </HBox>

            <Label fx:id="seedErrorLabel"
                   styleClass="status-label"
                   text=""
                   wrapText="true"
                   maxWidth="480"/>

        </VBox>

        <!-- STEP 2 PANEL — Modifier input (hidden initially) -->
        <VBox fx:id="step2Panel" alignment="CENTER"
              spacing="16" maxWidth="560"
              visible="false" managed="false">

            <!-- Confirmed seed chip -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="SEED SONG" styleClass="confirmed-label"/>
                <Label fx:id="confirmedSeedLabel"
                       text="" styleClass="confirmed-chip"/>
                <Button text="✕" styleClass="clear-chip-button"
                        onAction="#handleClearSeed"/>
            </HBox>

            <Label text="Now, how do you want to refine it?"
                   styleClass="step-question"/>
            <Label text="Describe the mood, energy, or style you're looking for. Or just hit Search to find similar songs."
                   styleClass="step-hint"
                   wrapText="true"
                   maxWidth="480"
                   textAlignment="CENTER"/>

            <HBox alignment="CENTER" spacing="12">
                <TextField fx:id="modifierField"
                           promptText="e.g.  but more dreamy and less mainstream"
                           styleClass="search-field"
                           prefHeight="52"
                           prefWidth="380"
                           onAction="#handleSearch"/>
                <Button text="→"
                        styleClass="search-button"
                        prefHeight="52"
                        prefWidth="52"
                        onAction="#handleSearch"/>
            </HBox>

            <!-- Options row -->
            <HBox alignment="CENTER" spacing="40">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Match query language" styleClass="option-label"/>
                    <ToggleButton fx:id="languageToggle"
                                  styleClass="toggle-button"
                                  selected="false"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Results" styleClass="option-label"/>
                    <ComboBox fx:id="songCountBox"
                              styleClass="count-box"
                              prefWidth="80"/>
                </HBox>
            </HBox>

            <Label fx:id="statusLabel"
                   styleClass="status-label"
                   text=""
                   wrapText="true"
                   maxWidth="480"/>

        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

    </VBox>
</StackPane>