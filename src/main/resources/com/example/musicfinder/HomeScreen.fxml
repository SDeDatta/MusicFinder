<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.musicfinder.HomeController"
           styleClass="root-pane">

<VBox styleClass="home-background"
      alignment="CENTER"
      spacing="34"
      prefWidth="1000"
      prefHeight="700">

    <!-- Title section -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="MUSIQ" styleClass="app-title"/>
        <Label text="Discover music through language" styleClass="app-subtitle"/>
    </VBox>

    <!-- Search section -->
    <VBox alignment="CENTER" spacing="18" maxWidth="680">

        <HBox alignment="CENTER" spacing="12" maxWidth="620">
            <TextField fx:id="searchField"
                       promptText="songs like Clocks by Coldplay but more dreamy..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"
                       prefHeight="54"
                       prefWidth="540"
                       onAction="#handleSearch"/>

            <Button fx:id="searchButton"
                    text="→"
                    styleClass="search-button"
                    prefHeight="54"
                    prefWidth="54"
                    onAction="#handleSearch"/>
        </HBox>

        <HBox alignment="CENTER" spacing="32">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Match query language" styleClass="option-label"/>
                <ToggleButton fx:id="languageToggle"
                              styleClass="toggle-button"
                              selected="false"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Results" styleClass="option-label"/>
                <ComboBox fx:id="songCountBox"
                          styleClass="count-box"
                          prefWidth="90"/>
            </HBox>
        </HBox>

        <Label fx:id="statusLabel"
               styleClass="status-label"
               text=""
               wrapText="true"
               maxWidth="560"/>
    </VBox>

</VBox>
</StackPane>